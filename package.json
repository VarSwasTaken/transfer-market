{
  "name": "transfer-market",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed:sql": "npx prisma db seed",
    "seed:nosql": "npx ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" ./prisma/seeds/seed_nosql.ts",
    "dedupe:sql": "npx ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" ./prisma/seeds/dedupe_sql.ts",
    "reset:players:sql": "npx ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" ./prisma/seeds/reset_players_sql.ts",
    "reseed:players:sql": "npm run reset:players:sql && npm run seed:sql",
    "reseed:players": "npm run reseed:players:sql && npm run seed:nosql",
    "test:integration:api": "node ./scripts/integration/api.integration.mjs",
    "test:integration:api:fresh": "npm run reseed:players && npm run test:integration:api"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@radix-ui/react-progress": "^1.1.8",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^1.9.0",
    "mongoose": "^9.5.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.39",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.5.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
